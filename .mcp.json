{
  "mcpServers": {
    "playwriter": {
      "command": "bunx",
      "args": [
        "-y",
        "playwriter@latest"
      ]
    },
    "chrome-devtools": {
      "command": "bunx",
      "args": [
        "chrome-devtools-mcp@latest",
        "--autoConnect",
        "--channel=beta"
      ]
    }
  }
}
